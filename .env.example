# OpenAI API Key
# 실제 제출 시 .env 파일은 Git에 올리지 않는다.
OPENAI_API_KEY=sk-your-api-key-here

# LLM model
OPENAI_MODEL=gpt-4o-mini

# Server port
PORT=3000

# Log file path
LOG_FILE_PATH=logs/access.log

# Redis Stack for RAG vector search
# Docker example: docker run -d --name redis-stack -p 6379:6379 redis/redis-stack:latest
REDIS_URL=redis://localhost:6379

# RAG settings
RAG_INDEX_NAME=my-tech-chatbot
RAG_DOCS_PATH=src/rag
RAG_AUTO_INDEX=false

# Embedding model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
